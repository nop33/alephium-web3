{
  "name": "@alephium/web3-wallet",
  "version": "2.0.9",
  "description": "Simple wallets for Alephium",
  "keywords": [
    "alephium",
    "web3"
  ],
  "license": "GPL",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:alephium/alephium-web3.git"
  },
  "homepage": "https://github.com/alephium/alephium-web3",
  "bugs": {
    "url": "https://github.com/alephium/alephium-web3/issues"
  },
  "author": "Alephium dev <dev@alephium.org>",
  "scripts": {
    "build": "rm -rf dist/* && vite build",
    "test": "jest -i --config ../../jest-config.json"
  },
  "dependencies": {
    "@alephium/web3": "workspace:^",
    "@noble/ciphers": "^2.1.1",
    "@noble/secp256k1": "1.7.1",
    "bip32": "3.1.0",
    "bip39": "3.0.4",
    "buffer": "6.0.3",
    "elliptic": "6.6.1",
    "fs-extra": "10.0.1",
    "@noble/hashes": "1.3.1"
  },
  "devDependencies": {
    "@types/find-up": "^2.1.1",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^27.5.2",
    "@types/mock-fs": "^4.13.1",
    "@types/node": "^16.18.23",
    "@types/rewire": "^2.5.28",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=7.0.0"
  }
}