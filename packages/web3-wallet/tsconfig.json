{
  "extends": "../../tsconfig.json",
  "include": [
    "src/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "templates",
    "src/**/*.test.ts",
    "src/**/fixtures/*"
  ],
  "compilerOptions": {
    "outDir": "dist",
    "moduleResolution": "node",
    "module": "esnext",
    "baseUrl": ".",
    "paths": {
      "@noble/hashes/*": [
        "node_modules/@noble/hashes/*",
        "../../node_modules/@noble/hashes/*"
      ],
      "@noble/ciphers/*": [
        "node_modules/@noble/ciphers/*",
        "../../node_modules/@noble/ciphers/*"
      ]
    }
  }
}