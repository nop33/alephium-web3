{
  "testSequencer": "<rootDir>/configs/testSequencer.js",
  "testPathIgnorePatterns": [
    ".*/node_modules/",
    ".*/templates/.*"
  ],
  "testMatch": [
    "**/(src|test)/**/*.test.ts"
  ],
  "moduleFileExtensions": [
    "ts",
    "tsx",
    "js",
    "jsx",
    "json",
    "node"
  ],
  "collectCoverage": true,
  "coverageDirectory": "./coverage/",
  "collectCoverageFrom": [
    "packages/*/src/**/*.ts",
    "!packages/web3-react/src/**/*.ts"
  ],
  "moduleDirectories": [
    "node_modules"
  ],
  "transformIgnorePatterns": [
    "node_modules/(?!(@noble/hashes|@noble/ciphers|@noble/secp256k1|bip32|@walletconnect)/)"
  ],
  "transform": {
    "^.+\\.(t|j)sx?$": [
      "ts-jest",
      {
        "useESM": true
      }
    ],
    "^.+\\.js$": [
      "babel-jest",
      {
        "presets": [
          [
            "@babel/preset-env",
            {
              "targets": {
                "node": "current"
              }
            }
          ]
        ]
      }
    ],
    "node_modules/@noble/.+\\.js$": [
      "ts-jest",
      {
        "useESM": true
      }
    ]
  },
  "moduleNameMapper": {
    "^@walletconnect/types$": "<rootDir>/node_modules/@walletconnect/types",
    "^@alephium/web3$": "<rootDir>/packages/web3/src/index.ts",
    "^@alephium/web3-wallet$": "<rootDir>/packages/web3-wallet/src/index.ts",
    "^@alephium/web3-test$": "<rootDir>/packages/web3-test/src/index.ts",
    "^@noble/hashes/(.*)$": "<rootDir>/node_modules/@noble/hashes/$1.js",
    "^@noble/ciphers/(.*)$": "<rootDir>/node_modules/@noble/ciphers/$1.js"
  }
}